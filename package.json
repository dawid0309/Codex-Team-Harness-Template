{
  "name": "codex-team-harness-template",
  "version": "0.1.0",
  "description": "Codex Team Harness Template: Provide a reusable Codex collaboration harness with agent context composition, milestone planning, and verification workflows.",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dawid0309/Codex-Team-Harness-Template.git"
  },
  "bugs": {
    "url": "https://github.com/dawid0309/Codex-Team-Harness-Template/issues"
  },
  "homepage": "https://github.com/dawid0309/Codex-Team-Harness-Template#readme",
  "keywords": [
    "codex",
    "template",
    "agents",
    "planning",
    "workflow",
    "verification"
  ],
  "scripts": {
    "sync:project": "tsx scripts/sync-project.ts",
    "init:project": "tsx scripts/init-project.ts",
    "compose:agents": "pnpm exec agents-md compose",
    "planner:refresh": "tsx scripts/lead-planner.ts refresh",
    "planner:next": "tsx scripts/lead-planner.ts next",
    "tasks:plan": "tsx scripts/harness/tasks.ts plan",
    "tasks:status": "tsx scripts/harness/tasks.ts status",
    "tasks:update": "tsx scripts/harness/tasks.ts update",
    "smoke": "tsx scripts/smoke.ts",
    "typecheck": "tsc --project tsconfig.json",
    "verify": "powershell -ExecutionPolicy Bypass -File scripts/verify.ps1"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "agents-md": "^1.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
