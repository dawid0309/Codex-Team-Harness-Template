{
  "name": "codex-harness-foundry",
  "version": "0.1.0",
  "description": "Codex Harness Foundry: Provide a reusable Codex collaboration harness with agent context composition, milestone planning, and verification workflows.",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dawid0309/Codex-Harness-Foundry.git"
  },
  "bugs": {
    "url": "https://github.com/dawid0309/Codex-Harness-Foundry/issues"
  },
  "homepage": "https://github.com/dawid0309/Codex-Harness-Foundry#readme",
  "keywords": [
    "codex",
    "template",
    "agents",
    "planning",
    "workflow",
    "verification"
  ],
  "scripts": {
    "harness": "tsx scripts/harness.ts",
    "harness:run": "tsx scripts/harness.ts run",
    "harness:eval": "tsx scripts/harness.ts eval",
    "harness:resume": "tsx scripts/harness.ts resume",
    "harness:doctor": "tsx scripts/harness.ts doctor",
    "harness:worker:start": "tsx scripts/harness-worker.ts start",
    "harness:worker:status": "tsx scripts/harness-worker.ts status",
    "harness:worker:stop": "tsx scripts/harness-worker.ts stop",
    "harness:worker:resume": "tsx scripts/harness-worker.ts resume",
    "harness:dashboard": "tsx scripts/harness-dashboard.ts",
    "langfuse:init": "tsx scripts/langfuse-local.ts init",
    "langfuse:up": "tsx scripts/langfuse-local.ts up",
    "langfuse:down": "tsx scripts/langfuse-local.ts down",
    "langfuse:logs": "tsx scripts/langfuse-local.ts logs",
    "langfuse:status": "tsx scripts/langfuse-local.ts status",
    "langfuse:open": "tsx scripts/langfuse-local.ts open",
    "langfuse:export": "tsx scripts/langfuse-export.ts",
    "sync:project": "tsx scripts/sync-project.ts",
    "init:project": "tsx scripts/init-project.ts",
    "compose:agents": "pnpm exec agents-md compose",
    "planner:propose": "tsx scripts/lead-planner.ts propose",
    "planner:publish": "tsx scripts/lead-planner.ts publish",
    "planner:refresh": "tsx scripts/lead-planner.ts refresh",
    "planner:next": "tsx scripts/lead-planner.ts next",
    "next-milestone:propose": "tsx scripts/next-milestone.ts propose",
    "next-milestone:publish": "tsx scripts/next-milestone.ts publish",
    "tasks:plan": "tsx scripts/harness/tasks.ts plan",
    "tasks:status": "tsx scripts/harness/tasks.ts status",
    "tasks:update": "tsx scripts/harness/tasks.ts update",
    "issues:export": "tsx scripts/issues-export.ts",
    "smoke": "tsx scripts/smoke.ts",
    "typecheck": "tsc --project tsconfig.json",
    "verify": "powershell -ExecutionPolicy Bypass -File scripts/verify.ps1"
  },
  "dependencies": {
    "@langfuse/client": "^5.2.0",
    "@langfuse/otel": "^5.2.0",
    "@langfuse/tracing": "^5.2.0",
    "@opentelemetry/sdk-node": "^0.215.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "agents-md": "^1.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
