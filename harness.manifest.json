{
  "version": 1,
  "defaultAdapter": "foundry",
  "artifactRoot": "data/harness",
  "adapters": {
    "foundry": {
      "id": "foundry",
      "label": "Foundry Adapter",
      "description": "Repo-native adapter that plans from the task board, executes a Codex sprint, and evaluates with configured verification stages.",
      "planner": {
        "kind": "task-board",
        "refreshCommand": "pnpm planner:refresh",
        "taskBoardPath": "planning/task-board.json",
        "milestonesPath": "planning/milestones.json"
      },
      "execution": {
        "kind": "codex-cli",
        "sandboxModeSource": "project.config.autonomy.sandboxMode",
        "basePromptSource": "project.config.autonomy.basePrompt",
        "resumePromptSource": "project.config.autonomy.resumePrompt",
        "modelSource": "project.config.autonomy.model",
        "defaultWriteScope": [
          "src",
          "tests",
          "docs",
          "planning",
          "agents",
          "agents-md",
          "scripts",
          "project.config.json",
          "README.md"
        ]
      },
      "evaluation": {
        "kind": "verification-stages",
        "projectConfigPath": "project.config.json"
      },
      "doctor": {
        "requiredFiles": [
          "harness.manifest.json",
          "project.config.json",
          "planning/milestones.json",
          "planning/task-board.json"
        ],
        "requiredCommands": [
          "pnpm --version",
          "codex --version"
        ]
      }
    },
    "external-generic": {
      "id": "external-generic",
      "label": "External Generic Adapter",
      "description": "External target adapter that plans from Foundry-side case files, executes Codex in the target repo, and evaluates with Foundry-side command definitions.",
      "planner": {
        "kind": "external-cases"
      },
      "execution": {
        "kind": "external-codex-cli"
      },
      "evaluation": {
        "kind": "external-commands"
      },
      "doctor": {
        "requiredFiles": [],
        "requiredCommands": []
      }
    }
  }
}
